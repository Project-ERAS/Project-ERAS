# Normalize text files and prefer LF in this repo.
* text=auto

# Source / config files: keep LF everywhere
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.scss text eol=lf

# Lockfiles
package-lock.json text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.svg  text eol=lf
*.ttf  binary
*.otf  binary
*.mp4  binary
*.mov  binary
